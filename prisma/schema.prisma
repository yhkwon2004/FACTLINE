// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id           String     @id @default(uuid())
  email        String     @unique
  name         String
  passwordHash String
  cases        Case[]
  lifeRecords  LifeRecord[]
  auditLogs    AuditLog[]
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  deletedAt    DateTime?
}

model Case {
  id            String          @id @default(uuid())
  title         String
  type          String
  description   String?
  status        String          @default("OPEN") // OPEN, IN_PROGRESS, CLOSED, ARCHIVED
  userId        String
  user          User            @relation(fields: [userId], references: [id])
  events        IncidentEvent[]
  evidences     Evidence[]
  lifeRecords   LifeRecord[]
  analysis      AnalysisResult?
  report        Report?
  isLocked      Boolean         @default(false)
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
  deletedAt     DateTime?
}

model IncidentEvent {
  id                  String     @id @default(uuid())
  caseId              String
  case                Case       @relation(fields: [caseId], references: [id])
  title               String
  rawStatement         String
  description         String
  datetime            DateTime?
  isApproximateTime   Boolean    @default(false)
  approximateTimeText String?
  location            String?
  actor               String?
  action              String?
  damage              String?
  source              String     @default("INTERVIEW") // INTERVIEW, EVIDENCE, MANUAL
  evidences           Evidence[]
  createdAt           DateTime   @default(now())
  updatedAt           DateTime   @updatedAt
}

model Evidence {
  id          String          @id @default(uuid())
  caseId      String
  case        Case            @relation(fields: [caseId], references: [id])
  name        String
  type        String
  fileUrl     String?
  fileHash    String?
  description String?
  events      IncidentEvent[]
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
}

model LifeRecord {
  id                  String   @id @default(uuid())
  userId              String
  user                User     @relation(fields: [userId], references: [id])
  caseId              String?
  case                Case?    @relation(fields: [caseId], references: [id])
  type                String   @default("NOTE") // NOTE, SCHEDULE, EVENT, ISSUE
  title               String
  content             String
  occurredAt          DateTime?
  approximateTimeText String?
  location            String?
  people              String?
  tags                String?  // JSON string
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
}

model AnalysisResult {
  id             String   @id @default(uuid())
  caseId         String   @unique
  case           Case     @relation(fields: [caseId], references: [id])
  riskLevel      String?
  risks          String?  // JSON string
  missingInfo    String?  // JSON string
  contradictions String?  // JSON string
  suggestions    String?  // JSON string
  content        String?  // The long-form text analysis
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model Report {
  id        String   @id @default(uuid())
  caseId    String   @unique
  case      Case     @relation(fields: [caseId], references: [id])
  content   String
  status    String   @default("DRAFT") // DRAFT, FINAL
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model LegalReference {
  id          String   @id @default(uuid())
  title       String
  description String
  category    String?
  citation    String?
  content     String
  sourceUrl   String?
  createdAt   DateTime @default(now())
}

model AuditLog {
  id        String   @id @default(uuid())
  userId    String?
  user      User?    @relation(fields: [userId], references: [id])
  action    String
  target    String?
  metadata  String?
  createdAt DateTime @default(now())
}
