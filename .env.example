DATABASE_URL="postgresql://postgres:postgres@localhost:5432/factline?schema=public"
DIRECT_URL="postgresql://postgres:postgres@localhost:5432/factline?schema=public"
APP_URL="http://localhost:3000"
NEXT_PUBLIC_APP_NAME="maze_FACTLINE"
JWT_SECRET="replace-with-long-random-secret"
ENCRYPTION_KEY="replace-with-32-byte-secret"
FACTLINE_STORAGE_MODE="prisma"

# Supabase Marketplace integration usually provides:
# POSTGRES_PRISMA_URL for DATABASE_URL and POSTGRES_URL_NON_POOLING for DIRECT_URL.

# Vercel AI Gateway / AI SDK. If unset, the app falls back to MockAIService.
AI_MODEL="openai/gpt-5.4"
AI_GATEWAY_API_KEY=""
VERCEL_OIDC_TOKEN=""

# On-device/local LLM mode. Supports OpenAI-compatible local servers such as Ollama, LM Studio, or vLLM.
# Example: AI_PROVIDER="local" LOCAL_LLM_ENDPOINT="http://localhost:11434/v1/chat/completions" LOCAL_LLM_MODEL="qwen2.5:7b"
AI_PROVIDER=""
LOCAL_LLM_ENDPOINT=""
LOCAL_LLM_MODEL=""

# Korean legal reference data. Use one of these official API credentials for live search.
# LAW_OPEN_API_OC: 국가법령정보센터 공동활용 OC value
# LAW_DATA_SERVICE_KEY: 공공데이터포털 법제처 국가법령정보 공유서비스 serviceKey
LAW_OPEN_API_OC=""
LAW_DATA_SERVICE_KEY=""
